//@version=5
strategy("⚡ Scalper Intradía V2 (Bollinger Quants)", shorttitle="V2 BB Scalper", overlay=true, initial_capital=10000, commission_type=strategy.commission.percent, commission_value=0.1, currency=currency.USD)

// ═══════════════════════════════════════════════
// MOTOR QUANT: BOLLINGER BANDS REVERSAL
// Objetivo: Cazar el efecto elástico de reversión a la media en temporalidad M15 / H1
// ═══════════════════════════════════════════════
length = 20
mult = 2.0
[middle, upper, lower] = ta.bb(close, length, mult)

// Dibujar el Canal de Volatilidad
plot(middle, color=color.new(#FFEB3B, 0), title="BB Middle (SMA 20)", linewidth=2)
plot(upper, color=color.new(#2962FF, 70), title="BB Upper")
plot(lower, color=color.new(#2962FF, 70), title="BB Lower")

rsi = ta.rsi(close, 14)

// ═══════════════════════════════════════════════
// CONDICIONES DE ENTRADA (SNAP-BACK ELASTIC)
// ═══════════════════════════════════════════════

// 1. El precio perforó o tocó la banda inferior (Mucha sobreventa direccional temporal)
perforo_banda = low <= lower or low[1] <= lower[1]

// 2. El elástico se estiró y ahora vuelve: El precio logra cerrar AL DENTRO del canal rebotando
recupera_canal = close > lower and close < middle

// 3. Confirmación de fuerza: RSI girando al alza (Oversold recovery)
rsi_ok = rsi < 45 and rsi > rsi[1]

// 4. Filtro de Spread: Exigimos que las Bandas estén algo abiertas. 
// Si la banda es plana (baja volatilidad), el TP central estará tan pegado que la comisión se comerá el rebote.
bb_width = (upper - lower) / middle
volatilidad_ok = bb_width > 0.025 // Al menos 2.5% de distancia total entre techos y pisos.

// Gatillo Final
buy_cond = perforo_banda and recupera_canal and rsi_ok and volatilidad_ok and strategy.position_size == 0

// ═══════════════════════════════════════════════
// GESTIÓN DE RIESGO ASIMÉTRICO (HIT & RUN)
// ═══════════════════════════════════════════════
var float stop_level = na
var float take_profit_level = na

if buy_cond
    // Entrar fuerte pero seguro (50% del capital). Comisiones de Binance Limits asumidas.
    strategy.entry("LONG", strategy.long, qty=(strategy.equity * 0.50) / close, comment="BB SNAP-BACK")
    
    // STOP LOSS ESTRICTO: -2.5% (Si el elástico se rompe e inicia una cascada, salimos cortando hemorragia)
    stop_level := close * 0.975
    
    // TAKE PROFIT GRAVITACIONAL: El precio tiende casi siempre a volver al medio (SMA 20).
    // Disparamos el objetivo allí de forma dinámica en el momento de la entrada.
    // Además, exigimos un piso mínimo de rentabilidad del +1.5% para cubrir las fees de sobremanera.
    objetivo_bb = middle
    objetivo_minimo = close * 1.015
    take_profit_level := math.max(objetivo_bb, objetivo_minimo)
    
    strategy.exit("TP/SL", "LONG", limit=take_profit_level, stop=stop_level)

// Limpiar dibujos visuales si no hay operación abierta
if strategy.position_size == 0
    stop_level := na
    take_profit_level := na

// Pintar SL y TP actuales de la operación en curso
plot(strategy.position_size > 0 ? stop_level : na, title="Hit SL (-2.5%)", color=color.new(#FF5252, 0), style=plot.style_linebr, linewidth=2)
plot(strategy.position_size > 0 ? take_profit_level : na, title="Hit TP (Línea Media)", color=color.new(#00E676, 0), style=plot.style_linebr, linewidth=2)
